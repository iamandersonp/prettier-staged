{
  "name": "@iamandersonp/prettier-staged",
  "version": "0.3.1",
  "main": "src/index.js",
  "bin": {
    "prettier-staged": "src/index.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prettier-staged": "src/index.js",
    "release": "standard-version",
    "setup:git-hooks": "node src/install-hooks.js",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "postinstall": "npm run setup:git-hooks"
  },
  "keywords": [
    "prettier",
    "staged",
    "git",
    "hooks",
    "formatting",
    "configurable",
    "extensions",
    "pre-commit"
  ],
  "author": "Anderson Penaloza <info@iamanderson.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamandersonp/prettier-staged.git"
  },
  "homepage": "https://github.com/iamandersonp/prettier-staged.git",
  "license": "GPL-3.0-only",
  "description": "Configurable utility to auto-format staged files using Prettier with customizable file extensions and hooks directory",
  "readme": "README.md",
  "dependencies": {
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "jest": "^30.3.0",
    "standard-version": "^9.5.0"
  }
}
